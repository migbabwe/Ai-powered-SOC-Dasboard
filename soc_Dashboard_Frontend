function SeverityBadge({ level, compact }) {
  const sev = typeof level === "string" ? level : getSeverityFromLevel(level);
  const cfg = SEV_CONFIG[sev];
  return (
    <span style={{
      display: "inline-flex", alignItems: "center", gap: 5,
      background: cfg.bg, color: cfg.color,
      border: `1px solid ${cfg.color}30`,
      borderRadius: 5, padding: compact ? "2px 7px" : "3px 10px",
      fontSize: compact ? 9 : 10, fontWeight: 700, letterSpacing: 1,
      fontFamily: "'JetBrains Mono', monospace",
      boxShadow: compact ? "none" : cfg.glow,
    }}>
      {!compact && <span style={{ width: 5, height: 5, borderRadius: "50%", background: cfg.color, display: "inline-block" }} />}
      {sev}
    </span>
  );
}

