function DevicesPage({ alerts }) {
  const agents = [...new Set(alerts.map(a => a.agent_name))].map(name => {
    const agentAlerts = alerts.filter(a => a.agent_name === name);
    const maxLevel = Math.max(...agentAlerts.map(a => a.level));
    const ip = agentAlerts[0].agent_ip;
    return { name, ip, alertCount: agentAlerts.length, maxLevel };
  });

  return (
    <div style={{ padding: 28 }}>
      <div style={{ marginBottom: 24 }}>
        <div style={{ fontSize: 11, color: "#00d4ff", letterSpacing: 3, marginBottom: 6, fontFamily: "'JetBrains Mono', monospace" }}>DEVICE INVENTORY</div>
        <div style={{ fontSize: 22, color: "#fff", fontWeight: 700 }}>Monitored Systems</div>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))", gap: 16 }}>
        {agents.map(agent => {
          const sev = getSeverityFromLevel(agent.maxLevel);
          const cfg = SEV_CONFIG[sev];
          return (
            <div key={agent.name} style={{
              background: "linear-gradient(135deg, #111827, #0d1520)",
              border: `1px solid ${cfg.color}30`, borderRadius: 12, padding: 20,
              boxShadow: `0 0 20px ${cfg.color}10`,
            }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 14 }}>
                <div style={{ fontSize: 28 }}>{agent.name.includes("workstation") ? "💻" : agent.name.includes("db") ? "🗄️" : "🖥️"}</div>
                <SeverityBadge level={agent.maxLevel} compact />
              </div>
              <div style={{ fontSize: 13, color: "#e5e7eb", fontWeight: 600, marginBottom: 4 }}>{agent.name}</div>
              <div style={{ fontSize: 10, color: "#6b7280", fontFamily: "'JetBrains Mono', monospace", marginBottom: 14 }}>{agent.ip}</div>
              <div style={{ display: "flex", justifyContent: "space-between", fontSize: 10, color: "#9ca3af" }}>
                <span>{agent.alertCount} alert{agent.alertCount !== 1 ? "s" : ""}</span>
