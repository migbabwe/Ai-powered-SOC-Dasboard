        level: 13,
        groups: ["privilege", "linux"],
        full_log: "/usr/bin/python3 -c 'import os; os.setuid(0); os.system(\"/bin/bash\")'",
      };
      setLiveAlerts(prev => [newAlert, ...prev]);
    }, 5000);
    return () => clearTimeout(t);
  }, []);

  function handleAnalyze() {
    if (!selectedAlert) return;
    setAiLoading(true);
    setTimeout(() => {
      setAiResults(prev => ({ ...prev, [selectedAlert.id]: AI_RESPONSES[selectedAlert.id] || AI_RESPONSES["ALT-006"] }));
      setAiLoading(false);
    }, 1800);
  }

  const filtered = liveAlerts.filter(a => {
    const matchSearch = a.rule_description.toLowerCase().includes(search.toLowerCase()) ||
      a.agent_name.toLowerCase().includes(search.toLowerCase()) ||
      a.id.toLowerCase().includes(search.toLowerCase());
    const matchSev = filterSev === "ALL" || getSeverityFromLevel(a.level) === filterSev;
    return matchSearch && matchSev;
  });

  const critCount = liveAlerts.filter(a => getSeverityFromLevel(a.level) === "CRITICAL").length;
  const highCount = liveAlerts.filter(a => getSeverityFromLevel(a.level) === "HIGH").length;

  return (
    <div style={{
      display: "flex", height: "100vh", background: "#080c12",
      color: "#e5e7eb", fontFamily: "'Inter', 'Segoe UI', sans-serif",
      overflow: "hidden",
    }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
        @keyframes ping { 0% { transform: scale(1); opacity: 0.5; } 75%, 100% { transform: scale(2); opacity: 0; } }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
        @keyframes slideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
      `}</style>

      <Sidebar page={page} setPage={setPage} alertCount={critCount + highCount} />

      <main style={{ flex: 1, display: "flex", flexDirection: "column", overflow: "hidden" }}>
        {/* Topbar */}
        <div style={{
          height: 56, borderBottom: "1px solid rgba(255,255,255,0.05)",
          display: "flex", alignItems: "center", justifyContent: "space-between",
          padding: "0 24px", background: "rgba(8,12,18,0.9)", backdropFilter: "blur(10px)",
          flexShrink: 0,
        }}>
          <div style={{ display: "flex", alignItems: "center", gap: 16 }}>
            <div style={{ fontSize: 12, color: "#9ca3af" }}>
              {page === "dashboard" && "Overview"}
              {page === "alerts" && "Alert Feed"}
              {page === "analysis" && "AI Analysis"}
              {page === "devices" && "Devices"}
            </div>
            {critCount > 0 && (
              <div style={{
                display: "flex", alignItems: "center", gap: 6,
                background: "rgba(255,59,92,0.1)", border: "1px solid rgba(255,59,92,0.3)",
                borderRadius: 20, padding: "4px 10px", fontSize: 10, color: "#ff3b5c",
                fontFamily: "'JetBrains Mono', monospace", letterSpacing: 0.5,
                animation: "pulse 2s ease-in-out infinite",
              }}>
                <PulsingDot color="#ff3b5c" />
                {critCount} CRITICAL THREAT{critCount !== 1 ? "S" : ""}
              </div>
            )}
          </div>
          <div style={{ fontSize: 10, color: "#4b5563", fontFamily: "'JetBrains Mono', monospace" }}>
            {new Date().toLocaleString("en-US", { hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false })} UTC
          </div>
        </div>

        {/* Content */}
        <div style={{ flex: 1, overflow: "hidden" }}>

          {/* DASHBOARD PAGE */}
          {page === "dashboard" && (
            <div style={{ height: "100%", overflowY: "auto", padding: 28 }}>
              <div style={{ marginBottom: 28 }}>
                <div style={{ fontSize: 11, color: "#00d4ff", letterSpacing: 3, marginBottom: 6, fontFamily: "'JetBrains Mono', monospace" }}>THREAT OVERVIEW</div>
                <div style={{ fontSize: 22, color: "#fff", fontWeight: 700 }}>Security Dashboard</div>
              </div>

              {/* Stat cards */}
              <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 16, marginBottom: 28 }}>
                <StatCard label="Total Alerts" value={liveAlerts.length} sublabel="↑ 3 in last hour" color="#00d4ff" icon="◈" />
                <StatCard label="Critical" value={critCount} sublabel="Immediate action" color="#ff3b5c" icon="⚠" />
                <StatCard label="High Severity" value={highCount} sublabel="Review today" color="#ff8c00" icon="◉" />
                <StatCard label="Agents Online" value={6} sublabel="All healthy" color="#22d3a5" icon="⬡" />
              </div>

              {/* Recent alerts preview */}
              <div style={{
                background: "linear-gradient(135deg, #111827, #0d1520)",
                border: "1px solid rgba(255,255,255,0.06)", borderRadius: 12, overflow: "hidden"
              }}>
                <div style={{ padding: "16px 20px", borderBottom: "1px solid rgba(255,255,255,0.05)", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <div style={{ fontSize: 12, color: "#9ca3af", fontFamily: "'JetBrains Mono', monospace", letterSpacing: 1 }}>RECENT ALERTS</div>
                  <button onClick={() => setPage("alerts")} style={{ fontSize: 10, color: "#00d4ff", background: "none", border: "none", cursor: "pointer", fontFamily: "'JetBrains Mono', monospace" }}>
                    VIEW ALL →
                  </button>
                </div>
                <div>
                  {liveAlerts.slice(0, 4).map(a => (
                    <div key={a.id} onClick={() => { setPage("alerts"); setSelectedAlert(a); }} style={{
                      display: "flex", justifyContent: "space-between", alignItems: "center",
                      padding: "12px 20px", borderBottom: "1px solid rgba(255,255,255,0.03)",
                      cursor: "pointer", transition: "background 0.15s",
                    }}
                      onMouseEnter={e => e.currentTarget.style.background = "rgba(255,255,255,0.02)"}
                      onMouseLeave={e => e.currentTarget.style.background = "transparent"}
                    >
                      <div>
                        <div style={{ fontSize: 12, color: "#e5e7eb", marginBottom: 2 }}>{a.rule_description}</div>
                        <div style={{ fontSize: 10, color: "#6b7280", fontFamily: "'JetBrains Mono', monospace" }}>{a.agent_name} · {fmt(a.timestamp)}</div>
                      </div>
                      <SeverityBadge level={a.level} compact />
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {/* ALERTS PAGE */}
          {page === "alerts" && (
            <div style={{ height: "100%", display: "flex", overflow: "hidden" }}>
              {/* Left: Alert table */}
              <div style={{ flex: 1, display: "flex", flexDirection: "column", overflow: "hidden", borderRight: "1px solid rgba(255,255,255,0.05)" }}>
                {/* Filters */}
                <div style={{ padding: "14px 20px", borderBottom: "1px solid rgba(255,255,255,0.05)", display: "flex", gap: 10, alignItems: "center", flexShrink: 0 }}>
                  <input
                    value={search} onChange={e => setSearch(e.target.value)}
                    placeholder="Search alerts..."
                    style={{
                      flex: 1, background: "rgba(255,255,255,0.05)", border: "1px solid rgba(255,255,255,0.08)",
                      borderRadius: 8, padding: "8px 12px", color: "#e5e7eb", fontSize: 12, outline: "none",
                    }}
                  />
                  {["ALL", "CRITICAL", "HIGH", "MEDIUM", "LOW"].map(s => (
                    <button key={s} onClick={() => setFilterSev(s)} style={{
                      padding: "6px 10px", borderRadius: 6, border: "none", cursor: "pointer", fontSize: 9,
                      fontFamily: "'JetBrains Mono', monospace", letterSpacing: 0.5, fontWeight: 700,
                      background: filterSev === s ? (SEV_CONFIG[s]?.bg || "rgba(0,212,255,0.15)") : "rgba(255,255,255,0.04)",
                      color: filterSev === s ? (SEV_CONFIG[s]?.color || "#00d4ff") : "#4b5563",
                      border: filterSev === s ? `1px solid ${SEV_CONFIG[s]?.color || "#00d4ff"}40` : "1px solid transparent",
                    }}>{s}</button>
                  ))}
                </div>

                {/* Table header */}
                <div style={{
                  display: "grid", gridTemplateColumns: "80px 1fr 120px 80px 60px",
                  gap: 12, padding: "8px 20px",
                  fontSize: 9, color: "#4b5563", fontFamily: "'JetBrains Mono', monospace", letterSpacing: 1,
                  borderBottom: "1px solid rgba(255,255,255,0.04)", flexShrink: 0,
                }}>
                  <div>ID</div><div>DESCRIPTION</div><div>TIME</div><div>SEVERITY</div><div>LEVEL</div>
                </div>

                {/* Rows */}
                <div style={{ flex: 1, overflowY: "auto" }}>
                  {filtered.map((a, i) => (
                    <div key={a.id} style={{ animation: `slideIn 0.2s ease ${i * 0.03}s both` }}>
                      <AlertRow alert={a} onSelect={al => { setSelectedAlert(al); setPage("alerts"); }} selected={selectedAlert?.id === a.id} />
                    </div>
                  ))}
                </div>
              </div>

              {/* Right: AI Panel */}
              <div style={{ width: 360, background: "linear-gradient(180deg, #0d1117, #0a0e13)", flexShrink: 0 }}>
                <AIPanel
                  alert={selectedAlert}
                  loading={aiLoading}
                  result={selectedAlert ? aiResults[selectedAlert.id] : null}
                  onAnalyze={handleAnalyze}
                />
              </div>
            </div>
          )}

          {/* ANALYSIS PAGE */}
          {page === "analysis" && (
            <div style={{ height: "100%", overflowY: "auto", padding: 28 }}>
              <div style={{ marginBottom: 24 }}>
                <div style={{ fontSize: 11, color: "#00d4ff", letterSpacing: 3, marginBottom: 6, fontFamily: "'JetBrains Mono', monospace" }}>AI ANALYSIS</div>
                <div style={{ fontSize: 22, color: "#fff", fontWeight: 700 }}>Threat Intelligence</div>
              </div>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(300px, 1fr))", gap: 16 }}>
                {liveAlerts.slice(0, 5).map(alert => {
                  const sev = getSeverityFromLevel(alert.level);
                  const cfg = SEV_CONFIG[sev];
                  const hasResult = !!aiResults[alert.id];
                  return (
                    <div key={alert.id} style={{
                      background: "linear-gradient(135deg, #111827, #0d1520)",
                      border: `1px solid ${hasResult ? cfg.color + "40" : "rgba(255,255,255,0.06)"}`,
                      borderRadius: 12, padding: 20,
                      boxShadow: hasResult ? `0 0 20px ${cfg.color}10` : "none",
                    }}>
                      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 12 }}>
                        <span style={{ fontSize: 10, color: "#00d4ff", fontFamily: "'JetBrains Mono', monospace" }}>{alert.id}</span>
                        <SeverityBadge level={alert.level} compact />
                      </div>
                      <div style={{ fontSize: 12, color: "#e5e7eb", marginBottom: 8, lineHeight: 1.5 }}>{alert.rule_description}</div>
                      <div style={{ fontSize: 10, color: "#6b7280", fontFamily: "'JetBrains Mono', monospace", marginBottom: 16 }}>{alert.agent_name}</div>
                      {hasResult ? (
                        <div style={{ fontSize: 11, color: "#9ca3af", lineHeight: 1.6 }}>
                          {aiResults[alert.id]?.summary?.slice(0, 120)}...
                          <div style={{ marginTop: 10, fontSize: 10, color: "#22d3a5" }}>✓ Analyzed · {aiResults[alert.id]?.recommended_action?.length} actions</div>
                        </div>
                      ) : (
                        <button onClick={() => { setSelectedAlert(alert); handleAnalyze(); }} style={{
                          width: "100%", padding: "8px", borderRadius: 6,
                          background: "rgba(0,212,255,0.08)", border: "1px solid rgba(0,212,255,0.2)",
                          color: "#00d4ff", fontSize: 10, cursor: "pointer", fontFamily: "'JetBrains Mono', monospace"
                        }}>✦ ANALYZE</button>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          {/* DEVICES PAGE */}
          {page === "devices" && <DevicesPage alerts={liveAlerts} />}
        </div>
      </main>
    </div>
  );
}
